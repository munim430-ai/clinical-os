{
  "buildCommand": "npx expo export --platform web --output-dir web-out",
  "installCommand": "npm install",
  "outputDirectory": "web-out",
  "cleanUrls": true,
  "framework": null,
  "redirects": [
    { "source": "/", "destination": "/home", "permanent": false }
  ],
  "rewrites": [
    { "source": "/auth", "destination": "/auth/index" },
    { "source": "/prescription", "destination": "/prescription/index" },
    { "source": "/wallet", "destination": "/wallet/index" },
    { "source": "/dims/brand/:id", "destination": "/dims/brand/[id]" },
    { "source": "/dims/generic/:id", "destination": "/dims/generic/[id]" },
    { "source": "/dims/generic", "destination": "/dims/generic/index" },
    { "source": "/dims/companies/:id", "destination": "/dims/companies/[id]" },
    { "source": "/dims/companies", "destination": "/dims/companies/index" },
    {
      "source": "/dims/interactions",
      "destination": "/dims/interactions/index"
    },
    { "source": "/gp/:system", "destination": "/gp/[system]" },
    { "source": "/gp/condition/:id", "destination": "/gp/condition/[id]" },
    { "source": "/gp/ecg/:id", "destination": "/gp/ecg/[id]" },
    { "source": "/gp/cxr/:id", "destination": "/gp/cxr/[id]" }
  ]
}
